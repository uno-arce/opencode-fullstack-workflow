{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "external_directory": {
      "~/Documents/*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "allow",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{file:.secrets/stitch-key.md}"
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "task": {
          "code-operator": "ask",
          "ui-designer": "ask"
        }
      }
    },
    "plan": {
      "color": "#6CE098",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "task": {
          "code-architect": "ask",
          "schema-architect": "ask"
        }
      }
    },
    "test": {
      "color": "#D56B01",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "task": {
          "code-tester": "ask",
          "e2e-tester": "ask"
        }
      }
    }
  }
}